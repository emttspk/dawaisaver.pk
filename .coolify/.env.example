# Coolify API Configuration
# Copy this file to .env.coolify and fill in your values

# Your Coolify instance URL (no trailing slash)
# Example: https://coolify.yourdomain.com or http://your-server-ip
COOLIFY_URL=https://your-coolify-instance.com

# Your API token with read, write, and deploy permissions
# Generate at: Coolify Dashboard -> Settings -> API Tokens
COOLIFY_TOKEN=your_api_token_here

# Quick setup:
#   cp .coolify/.env.example .coolify/.env.coolify
#   Edit .coolify/.env.coolify with your values
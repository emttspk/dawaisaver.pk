{
  "name": "dawaisaver-pk-api",
  "version": "0.1.0",
  "private": true,
  "description": "DawaiSaver.pk medicine intelligence backend runtime",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:cli": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "catalog:build": "ts-node -r dotenv/config src/cli/catalog.ts build",
    "catalog:resume": "ts-node -r dotenv/config src/cli/catalog.ts resume",
    "catalog:verify": "ts-node -r dotenv/config src/cli/catalog.ts verify",
    "canonical:grouping": "ts-node -r dotenv/config src/cli/canonical-grouping.ts",
    "drap:mirror": "ts-node -r dotenv/config src/cli/drap-mirror.ts",
    "master:build": "ts-node -r dotenv/config src/cli/master-builder.ts",
    "json:generate": "ts-node -r dotenv/config src/cli/generate-json.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\"",
    "test": "jest",
    "test:unit": "jest --config jest.config.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:bootstrap": "npm run prisma:generate && npm run prisma:migrate",
    "benchmark:drap": "npx ts-node -r dotenv/config src/benchmark/drap-benchmark.mock.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.2.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-xml-parser": "^5.9.2",
    "helmet": "^8.0.0",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "multer": "^2.2.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}

model CompositionGroupComposition {
  id                 String           @id @default(uuid()) @db.Uuid
  compositionGroupId String           @map("composition_group_id") @db.Uuid
  genericId          String           @map("generic_id") @db.Uuid
  strengthValue      Decimal?         @map("strength_value") @db.Decimal(12, 4)
  strengthUnit       String?          @map("strength_unit")
  ingredientOrder    Int              @default(1) @map("ingredient_order")
  status             RecordStatus     @default(ACTIVE)
  confidenceScore    Decimal?         @map("confidence_score") @db.Decimal(5, 4)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  PENDING_REVIEW
  VERIFIED
  REJECTED
  ARCHIVED
  DELETED

  @@map("record_status")
}

enum SourceType {
  DRAP
  DRAP_UPDATE
  MANUFACTURER
  ONLINE_PHARMACY
  USER_BILL
  USER_PRESCRIPTION
  ADMIN_IMPORT
  ADMIN_REVIEW
  SYSTEM

  @@map("source_type")
}

enum ImportBatchStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED

  @@map("import_batch_status")
}

enum ImportItemStatus {
  PENDING
  VALIDATED
  NORMALIZED
  SAVED
  DUPLICATE
  FAILED

  @@map("import_item_status")
}

enum SourceProviderKind {
  DAWAAI
  SEHAT
  DVAGO
  SERVAID
  ONLINE_PHARMACY
  API

  @@map("source_provider_kind")
}

enum SourceSyncStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED

  @@map("source_sync_status")
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LIMITED
  UNKNOWN

  @@map("stock_status")
}

enum PriceChangeDirection {
  INCREASE
  DECREASE
  UNCHANGED
  NEW

  @@map("price_change_direction")
}

enum PriceAnomalyType {
  EXTREME_PRICING
  SUSPICIOUS_DROP
  SUSPICIOUS_SPIKE
  DUPLICATE_PRICE
  INVALID_PRICE

  @@map("price_anomaly_type")
}

enum MarketSignalType {
  BEST_PRICE
  RECOMMENDED_PRICE
  MARKET_AVERAGE

  @@map("market_signal_type")
}

enum MatchResultStatus {
  MATCHED
  POSSIBLE_MATCH
  NEEDS_REVIEW
  UNMATCHED

  @@map("match_result_status")
}

enum MatchReviewStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
  SPLIT

  @@map("match_review_status")
}

enum CanonicalAliasType {
  BRAND
  GENERIC
  MANUFACTURER
  SIGNATURE
  REGISTRATION_NUMBER
  PACK_SIZE

  @@map("canonical_alias_type")
}

enum MatchingRuleType {
  BRAND
  GENERIC
  STRENGTH
  DOSAGE_FORM
  MANUFACTURER
  PACK_SIZE
  REGISTRATION_NUMBER
  SIGNATURE
  CONFIDENCE

  @@map("matching_rule_type")
}

enum SearchEntityType {
  PRODUCT
  GENERIC
  MANUFACTURER
  SIGNATURE
  ALTERNATIVE

  @@map("search_entity_type")
}

enum SearchSuggestionType {
  BRAND
  GENERIC
  MANUFACTURER
  SIGNATURE
  REGISTRATION_NUMBER
  CITY

  @@map("search_suggestion_type")
}

enum DiscoverySourceType {
  DRAP_IMPORT
  PHARMACY_SNAPSHOT
  SEARCH_QUERY
  UNKNOWN_PRODUCT
  BILL_IMPORT
  PRESCRIPTION_IMPORT
  ADMIN_IMPORT

  @@map("discovery_source_type")
}

enum DiscoveryStatus {
  NEW
  COLLECTING_EVIDENCE
  NEEDS_REVIEW
  APPROVED
  REJECTED
  MERGED

  @@map("discovery_status")
}

enum DiscoveryReviewDecision {
  APPROVE
  REJECT
  MERGE
  REQUEST_MORE_EVIDENCE

  @@map("discovery_review_decision")
}

enum DiscoveryRuleType {
  CANDIDATE_GENERATION
  EVIDENCE_CONFIDENCE
  DUPLICATE_DETECTION
  REVIEW_ROUTING
  AUTO_MERGE_GUARD

  @@map("discovery_rule_type")
}

enum UserRole {
  USER
  ADMIN
  REVIEWER

  @@map("user_role")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  IMPORT
  NORMALIZE
  REVIEW
  MATCH
  PRICE_OBSERVATION
  SEARCH

  @@map("audit_action")
}

model User {
  id                    String         @id @default(uuid()) @db.Uuid
  email                 String?        @unique
  phone                 String?        @unique
  name                  String?
  passwordHash          String?        @map("password_hash")
  refreshTokenHash      String?        @map("refresh_token_hash")
  refreshTokenExpiresAt DateTime?      @map("refresh_token_expires_at")
  role                  UserRole       @default(USER)
  status                RecordStatus   @default(ACTIVE)
  confidenceScore       Decimal?       @map("confidence_score") @db.Decimal(5, 4)
  sourceType            SourceType?    @map("source_type")
  sourceUrl             String?        @map("source_url")
  metadata              Json?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deletedAt             DateTime?      @map("deleted_at")
  createdById           String?        @map("created_by_id") @db.Uuid
  updatedById           String?        @map("updated_by_id") @db.Uuid
  deletedById           String?        @map("deleted_by_id") @db.Uuid
  prescriptions         Prescription[]
  bills                 Bill[]
  searchLogs            SearchLog[]
  auditLogs             AuditLog[]
  matchReviews          MatchReview[]
  reportedReports       UserReport[]   @relation("UserReports")
  reviewedReports       UserReport[]   @relation("UserReviewedReports")

  @@map("users")
}

model Manufacturer {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  normalizedName  String               @map("normalized_name")
  aliases         String[]             @default([])
  country         String?
  websiteUrl      String?              @map("website_url")
  status          RecordStatus         @default(PENDING_REVIEW)
  confidenceScore Decimal?             @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?          @map("source_type")
  sourceUrl       String?              @map("source_url")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")
  createdById     String?              @map("created_by_id") @db.Uuid
  updatedById     String?              @map("updated_by_id") @db.Uuid
  deletedById     String?              @map("deleted_by_id") @db.Uuid
  products        Product[]
  importItems     ImportBatchItem[]
  profile         ManufacturerProfile?

  @@index([normalizedName])
  @@index([status])
  @@map("manufacturers")
}

model Generic {
  id                 String                        @id @default(uuid()) @db.Uuid
  name               String
  normalizedName     String                        @map("normalized_name")
  aliases            String[]                      @default([])
  status             RecordStatus                  @default(PENDING_REVIEW)
  confidenceScore    Decimal?                      @map("confidence_score") @db.Decimal(5, 4)
  sourceType         SourceType?                   @map("source_type")
  sourceUrl          String?                       @map("source_url")
  metadata           Json?
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")
  deletedAt          DateTime?                     @map("deleted_at")
  createdById        String?                       @map("created_by_id") @db.Uuid
  updatedById        String?                       @map("updated_by_id") @db.Uuid
  deletedById        String?                       @map("deleted_by_id") @db.Uuid
  compositions       ProductComposition[]
  compositionGroups  CompositionGroupComposition[]
  atcClassifications GenericAtcClassification[]

  @@unique([normalizedName])
  @@index([status])
  @@map("generics")
}

model Product {
  id                    String                       @id @default(uuid()) @db.Uuid
  manufacturerId        String?                      @map("manufacturer_id") @db.Uuid
  brandName             String                       @map("brand_name")
  normalizedBrand       String                       @map("normalized_brand")
  displayName           String                       @map("display_name")
  dosageForm            String?                      @map("dosage_form")
  normalizedForm        String?                      @map("normalized_form")
  strengthText          String?                      @map("strength_text")
  packSize              String?                      @map("pack_size")
  registrationNumber    String?                      @map("registration_number")
  signature             String?
  status                RecordStatus                 @default(PENDING_REVIEW)
  confidenceScore       Decimal?                     @map("confidence_score") @db.Decimal(5, 4)
  sourceType            SourceType?                  @map("source_type")
  sourceUrl             String?                      @map("source_url")
  metadata              Json?
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  deletedAt             DateTime?                    @map("deleted_at")
  createdById           String?                      @map("created_by_id") @db.Uuid
  updatedById           String?                      @map("updated_by_id") @db.Uuid
  deletedById           String?                      @map("deleted_by_id") @db.Uuid
  manufacturer          Manufacturer?                @relation(fields: [manufacturerId], references: [id])
  compositions          ProductComposition[]
  equivalences          ProductEquivalence[]
  prices                ProductPrice[]
  prescriptionItems     PrescriptionItem[]
  billItems             BillItem[]
  importItems           ImportBatchItem[]
  priceSnapshots        PriceSnapshot[]
  priceChangeEvents     PriceChangeEvent[]
  availability          ProductAvailability[]
  priceStatistics       ProductPriceStatistic[]
  cityPriceStatistics   CityPriceStatistic[]
  marketSignals         MarketPriceSignal[]
  priceAnomalies        PriceAnomaly[]
  priceTrends           PriceTrend[]
  canonicalProduct      CanonicalProduct?
  productMatches        ProductMatch[]
  packs                 ProductPack[]
  therapeuticCategories ProductTherapeuticCategory[]

  @@index([manufacturerId])
  @@index([normalizedBrand])
  @@index([signature])
  @@index([registrationNumber])
  @@index([status])
  @@map("products")
}

model ProductComposition {
  id              String       @id @default(uuid()) @db.Uuid
  productId       String       @map("product_id") @db.Uuid
  genericId       String       @map("generic_id") @db.Uuid
  ingredientOrder Int          @default(1) @map("ingredient_order")
  strengthValue   Decimal?     @map("strength_value") @db.Decimal(12, 4)
  strengthUnit    String?      @map("strength_unit")
  strengthText    String?      @map("strength_text")
  status          RecordStatus @default(PENDING_REVIEW)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?  @map("source_type")
  sourceUrl       String?      @map("source_url")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  product         Product      @relation(fields: [productId], references: [id])
  generic         Generic      @relation(fields: [genericId], references: [id])

  @@unique([productId, genericId, ingredientOrder])
  @@index([genericId])
  @@index([status])
  @@map("product_compositions")
}

model EquivalenceGroup {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  signature       String
  equivalenceType String               @map("equivalence_type")
  dosageForm      String?              @map("dosage_form")
  status          RecordStatus         @default(PENDING_REVIEW)
  confidenceScore Decimal?             @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?          @map("source_type")
  sourceUrl       String?              @map("source_url")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")
  createdById     String?              @map("created_by_id") @db.Uuid
  updatedById     String?              @map("updated_by_id") @db.Uuid
  deletedById     String?              @map("deleted_by_id") @db.Uuid
  products        ProductEquivalence[]

  @@index([signature])
  @@index([status])
  @@map("equivalence_groups")
}

model ProductEquivalence {
  id                 String           @id @default(uuid()) @db.Uuid
  productId          String           @map("product_id") @db.Uuid
  equivalenceGroupId String           @map("equivalence_group_id") @db.Uuid
  reasonCode         String?          @map("reason_code")
  status             RecordStatus     @default(PENDING_REVIEW)
  confidenceScore    Decimal?         @map("confidence_score") @db.Decimal(5, 4)
  sourceType         SourceType?      @map("source_type")
  sourceUrl          String?          @map("source_url")
  metadata           Json?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  createdById        String?          @map("created_by_id") @db.Uuid
  updatedById        String?          @map("updated_by_id") @db.Uuid
  deletedById        String?          @map("deleted_by_id") @db.Uuid
  product            Product          @relation(fields: [productId], references: [id])
  equivalenceGroup   EquivalenceGroup @relation(fields: [equivalenceGroupId], references: [id])

  @@unique([productId, equivalenceGroupId])
  @@index([equivalenceGroupId])
  @@index([status])
  @@map("product_equivalence")
}

model Pharmacy {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  normalizedName  String         @map("normalized_name")
  city            String?
  licenseNumber   String?        @map("license_number")
  address         String?
  phone           String?
  websiteUrl      String?        @map("website_url")
  isPartner       Boolean        @default(false) @map("is_partner")
  status          RecordStatus   @default(PENDING_REVIEW)
  confidenceScore Decimal?       @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?    @map("source_type")
  sourceUrl       String?        @map("source_url")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdById     String?        @map("created_by_id") @db.Uuid
  updatedById     String?        @map("updated_by_id") @db.Uuid
  deletedById     String?        @map("deleted_by_id") @db.Uuid
  prices          ProductPrice[]
  bills           Bill[]

  @@index([normalizedName])
  @@index([city])
  @@index([status])
  @@map("pharmacies")
}

model ProductPrice {
  id              String       @id @default(uuid()) @db.Uuid
  productId       String       @map("product_id") @db.Uuid
  pharmacyId      String?      @map("pharmacy_id") @db.Uuid
  city            String?
  price           Decimal      @db.Decimal(12, 2)
  currency        String       @default("PKR")
  observedAt      DateTime     @default(now()) @map("observed_at")
  availability    String?
  status          RecordStatus @default(PENDING_REVIEW)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?  @map("source_type")
  sourceUrl       String?      @map("source_url")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  product         Product      @relation(fields: [productId], references: [id])
  pharmacy        Pharmacy?    @relation(fields: [pharmacyId], references: [id])

  @@index([productId, observedAt])
  @@index([pharmacyId])
  @@index([city])
  @@index([sourceType])
  @@map("product_prices")
}

model Prescription {
  id              String                      @id @default(uuid()) @db.Uuid
  userId          String?                     @map("user_id") @db.Uuid
  uploadUrl       String?                     @map("upload_url")
  ocrText         String?                     @map("ocr_text")
  status          RecordStatus                @default(PENDING_REVIEW)
  confidenceScore Decimal?                    @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?                 @map("source_type")
  sourceUrl       String?                     @map("source_url")
  metadata        Json?
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  deletedAt       DateTime?                   @map("deleted_at")
  createdById     String?                     @map("created_by_id") @db.Uuid
  updatedById     String?                     @map("updated_by_id") @db.Uuid
  deletedById     String?                     @map("deleted_by_id") @db.Uuid
  user            User?                       @relation(fields: [userId], references: [id])
  items           PrescriptionItem[]
  processingJobs  PrescriptionProcessingJob[]
  reviews         PrescriptionReview[]
  costEstimates   PrescriptionCostEstimate[]

  @@index([userId])
  @@index([status])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              String                     @id @default(uuid()) @db.Uuid
  prescriptionId  String                     @map("prescription_id") @db.Uuid
  productId       String?                    @map("product_id") @db.Uuid
  rawText         String                     @map("raw_text")
  parsedName      String?                    @map("parsed_name")
  dosageText      String?                    @map("dosage_text")
  quantity        Decimal?                   @db.Decimal(12, 4)
  status          RecordStatus               @default(PENDING_REVIEW)
  confidenceScore Decimal?                   @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?                @map("source_type")
  sourceUrl       String?                    @map("source_url")
  metadata        Json?
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  deletedAt       DateTime?                  @map("deleted_at")
  createdById     String?                    @map("created_by_id") @db.Uuid
  updatedById     String?                    @map("updated_by_id") @db.Uuid
  deletedById     String?                    @map("deleted_by_id") @db.Uuid
  prescription    Prescription               @relation(fields: [prescriptionId], references: [id])
  product         Product?                   @relation(fields: [productId], references: [id])
  reviews         PrescriptionReview[]
  costEstimates   PrescriptionCostEstimate[]

  @@index([prescriptionId])
  @@index([productId])
  @@index([status])
  @@map("prescription_items")
}

model PrescriptionProcessingJob {
  id              String       @id @default(uuid()) @db.Uuid
  prescriptionId  String       @map("prescription_id") @db.Uuid
  jobType         String       @map("job_type")
  status          RecordStatus @default(PENDING_REVIEW)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?  @map("source_type")
  sourceUrl       String?      @map("source_url")
  city            String?
  metadata        Json?
  resultSummary   Json?        @map("result_summary")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  prescription    Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
  @@index([jobType])
  @@index([status])
  @@map("prescription_processing_jobs")
}

model PrescriptionReview {
  id                 String            @id @default(uuid()) @db.Uuid
  prescriptionId     String            @map("prescription_id") @db.Uuid
  prescriptionItemId String?           @map("prescription_item_id") @db.Uuid
  reviewStatus       String            @map("review_status")
  reviewDecision     String            @map("review_decision")
  reviewNotes        String?           @map("review_notes")
  status             RecordStatus      @default(PENDING_REVIEW)
  confidenceScore    Decimal?          @map("confidence_score") @db.Decimal(5, 4)
  sourceType         SourceType?       @map("source_type")
  sourceUrl          String?           @map("source_url")
  metadata           Json?
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  createdById        String?           @map("created_by_id") @db.Uuid
  updatedById        String?           @map("updated_by_id") @db.Uuid
  deletedById        String?           @map("deleted_by_id") @db.Uuid
  prescription       Prescription      @relation(fields: [prescriptionId], references: [id])
  prescriptionItem   PrescriptionItem? @relation(fields: [prescriptionItemId], references: [id])

  @@index([prescriptionId])
  @@index([prescriptionItemId])
  @@index([status])
  @@map("prescription_reviews")
}

model PrescriptionCostEstimate {
  id                     String            @id @default(uuid()) @db.Uuid
  prescriptionId         String            @map("prescription_id") @db.Uuid
  prescriptionItemId     String?           @map("prescription_item_id") @db.Uuid
  city                   String?
  originalEstimatedCost  Decimal           @map("original_estimated_cost") @db.Decimal(12, 2)
  cheapestEquivalentCost Decimal           @map("cheapest_equivalent_cost") @db.Decimal(12, 2)
  balancedOptionCost     Decimal           @map("balanced_option_cost") @db.Decimal(12, 2)
  premiumOptionCost      Decimal           @map("premium_option_cost") @db.Decimal(12, 2)
  estimatedSaving        Decimal           @map("estimated_saving") @db.Decimal(12, 2)
  reviewRequired         Boolean           @default(false) @map("review_required")
  status                 RecordStatus      @default(PENDING_REVIEW)
  confidenceScore        Decimal?          @map("confidence_score") @db.Decimal(5, 4)
  sourceType             SourceType?       @map("source_type")
  sourceUrl              String?           @map("source_url")
  metadata               Json?
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  deletedAt              DateTime?         @map("deleted_at")
  createdById            String?           @map("created_by_id") @db.Uuid
  updatedById            String?           @map("updated_by_id") @db.Uuid
  deletedById            String?           @map("deleted_by_id") @db.Uuid
  prescription           Prescription      @relation(fields: [prescriptionId], references: [id])
  prescriptionItem       PrescriptionItem? @relation(fields: [prescriptionItemId], references: [id])

  @@index([prescriptionId])
  @@index([prescriptionItemId])
  @@index([city])
  @@index([status])
  @@map("prescription_cost_estimates")
}

model Bill {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String?      @map("user_id") @db.Uuid
  pharmacyId      String?      @map("pharmacy_id") @db.Uuid
  uploadUrl       String?      @map("upload_url")
  ocrText         String?      @map("ocr_text")
  purchasedAt     DateTime?    @map("purchased_at")
  totalAmount     Decimal?     @map("total_amount") @db.Decimal(12, 2)
  status          RecordStatus @default(PENDING_REVIEW)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?  @map("source_type")
  sourceUrl       String?      @map("source_url")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  user            User?        @relation(fields: [userId], references: [id])
  pharmacy        Pharmacy?    @relation(fields: [pharmacyId], references: [id])
  items           BillItem[]

  @@index([userId])
  @@index([pharmacyId])
  @@index([status])
  @@map("bills")
}

model BillItem {
  id              String       @id @default(uuid()) @db.Uuid
  billId          String       @map("bill_id") @db.Uuid
  productId       String?      @map("product_id") @db.Uuid
  rawText         String       @map("raw_text")
  parsedName      String?      @map("parsed_name")
  quantity        Decimal?     @db.Decimal(12, 4)
  unitPrice       Decimal?     @map("unit_price") @db.Decimal(12, 2)
  lineTotal       Decimal?     @map("line_total") @db.Decimal(12, 2)
  status          RecordStatus @default(PENDING_REVIEW)
  confidenceScore Decimal?     @map("confidence_score") @db.Decimal(5, 4)
  sourceType      SourceType?  @map("source_type")
  sourceUrl       String?      @map("source_url")
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by_id") @db.Uuid
  updatedById     String?      @map("updated_by_id") @db.Uuid
  deletedById     String?      @map("deleted_by_id") @db.Uuid
  bill            Bill         @relation(fields: [billId], references: [id])
